# Copie para .env e preencha com valores reais. O arquivo .env nunca deve ser commitado.

# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SAUDE_SIMPLES_SECRET_KEY=

# Senha: não precisa configurar aqui. Rode `python resetar_senha.py` pra definir a senha
# inicial (máquina nova) ou redefinir caso tenha esquecido — funciona sem saber a senha atual.
# Depois do primeiro acesso, a senha também pode ser trocada pela tela "Trocar senha" dentro
# do sistema (ícone de chave no menu).
#
# Esta variável só existe para setups automatizados/scriptados que preferem definir a senha
# via .env em vez de interativamente. Se for usar, gere com:
# python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('sua-senha'))"
SAUDE_SIMPLES_PASSWORD_HASH=

# true para usar o servidor de desenvolvimento do Flask; false (ou ausente) usa waitress (produção)
SAUDE_SIMPLES_DEBUG=false

# Opcionais (têm padrão se não definidos)
# SAUDE_SIMPLES_HOST=127.0.0.1
# SAUDE_SIMPLES_PORT=5001
