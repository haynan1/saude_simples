# Copie para .env e preencha com valores reais. O arquivo .env nunca deve ser commitado.

# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SAUDE_SIMPLES_SECRET_KEY=

# Gere com: python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('sua-senha'))"
SAUDE_SIMPLES_PASSWORD_HASH=

# true para usar o servidor de desenvolvimento do Flask; false (ou ausente) usa waitress (produção)
SAUDE_SIMPLES_DEBUG=false

# Opcionais (têm padrão se não definidos)
# SAUDE_SIMPLES_HOST=127.0.0.1
# SAUDE_SIMPLES_PORT=5001
